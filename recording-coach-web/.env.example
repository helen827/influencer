# 端口（默认 3847；云上平台一般会注入 PORT）
# PORT=3847
# 仅本机监听时可设：LISTEN_HOST=127.0.0.1（默认 0.0.0.0 便于 Docker/云主机）
# LISTEN_HOST=0.0.0.0

# 方式一：七牛 AI（与 MeetingPilot 一致）
# 「实时听我说」的语音识别也走七牛，需此 Key（sk- 开头）
QINIU_AI_API_KEY=
# 可选，默认 deepseek-v3
# QINIU_LLM_MODEL=deepseek-v3

# 方式二：Cursor / 其它 OpenAI 兼容（需同时填 Base URL，一般以 /v1 结尾；未配置七牛时使用）
# 密钥来自 Cursor 控制台等；Base URL 以服务商文档为准。
# CURSOR_API_KEY=
# CURSOR_API_BASE_URL=https://example.com/v1
# CURSOR_LLM_MODEL=gpt-4o-mini

# 方式三：OpenAI 官方或其它兼容（未配置上面时使用）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 联网搜索（默认开启；设为 0 可关闭，仅用主题/转录生成问题）
# RECORDING_COACH_WEB_SEARCH=1
# SEARCH_PROVIDER=duckduckgo
# 可选 Serper（更稳定）：SEARCH_PROVIDER=serper 并配置 SERPER_API_KEY
# SERPER_API_KEY=
# SERPER_GL=cn
# SERPER_HL=zh-cn
